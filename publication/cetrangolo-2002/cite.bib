@article{cetrangolo2002,
 abstract = {Argentina is today the first sunflower oil producer and exporter. Its competitiveness relies on being highly efficient in the primary production and industrialization stages. However, this sector is threatened by several implemented mechanisms that distorted the international market. This paper presents an updated overview of Argentinean sunflower agrifood chain situation, describing primary production, industry, commercialization and main mechanisms that limit its competitiveness.},
 author = {H. Cetrángolo and M. Carlevaro and S. Fernández},
 journal = {New Medit Journal of Economics, Agriculture and Environment},
 month = {Jun},
 number = {2},
 pages = {34--40},
 title = {Limitations for competitiveness in Argentinian sunflower agrifood chain},
 volume = {1},
 year = {2002}
}

